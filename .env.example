# ─── RPC ───────────────────────────────────────────────────
BASE_SEPOLIA_RPC=https://sepolia.base.org

# ─── Keys ──────────────────────────────────────────────────
# Deployer is also the protocol admin
DEPLOYER_PRIVATE_KEY=0x...
# Vault manager — separate key for VM operations
VM_PRIVATE_KEY=0x...

# ─── Addresses ─────────────────────────────────────────────
# Treasury receives protocol fee share
TREASURY_ADDRESS=0x...
# Vault manager address (derived from VM_PRIVATE_KEY or set explicitly)
VM_ADDRESS=0x...

# ─── Deployed Contracts (populated after Deploy.s.sol) ─────
PROTOCOL_REGISTRY=
ASSET_REGISTRY=
PYTH_ORACLE=
OWN_MARKET=
VAULT_MANAGER=
ETOKEN_FACTORY=
MOCK_USDC=
ETOKEN_TSLA=
ETOKEN_GOLD=
WETH_ROUTER=

# ─── Testnet Helpers ────────────────────────────────────────
# Set to true to deploy a MockWETH instead of using real WETH on testnet.
DEPLOY_MOCK_WETH=false

# ─── Deployed Vault (populated after CreateVault.s.sol) ────
VAULT_ADDRESS=

# ─── Etherscan ─────────────────────────────────────────────
BASESCAN_API_KEY=

# ─── Robinhood Chain (4663) ─────────────────────────────────
# Explorer: https://robinhoodchain.blockscout.com (Blockscout — no Etherscan; no API key needed)
ROBINHOOD_RPC=https://rpc.mainnet.chain.robinhood.com
DEPLOYER_PRIVATE_KEY_ROBINHOOD=0x...
VM_PRIVATE_KEY_ROBINHOOD=0x...
VM_ADDRESS_ROBINHOOD=0x...
TREASURY_ADDRESS_ROBINHOOD=0x...
ORACLE_SIGNER_ROBINHOOD=0x...
OPERATOR_PRIVATE_KEY_ROBINHOOD=0x...
QUOTE_SIGNER_ROBINHOOD=0x...
QUOTE_SIGNER_LINKED_ROBINHOOD=0x...
RESERVE_MANAGER_ROBINHOOD=0x...
# Populated after DeployRobinhood.s.sol
PROTOCOL_REGISTRY_ROBINHOOD=
VAULT_ADDRESS_ROBINHOOD=
LENDING_POOL_ROBINHOOD=
LENDING_ROUTER_ROBINHOOD=
# For test/fork/WrapperRobinhoodFork.t.sol (Gen-2 token due diligence)
WRAPPER_TOKEN_ROBINHOOD=
